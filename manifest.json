{
  "name": "Eye Protector",
  "description": "Reminds you to rest your eyes: 20 minutes work / 20 seconds break.",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_title": "Eye Protector"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "notifications"
  ],
  "homepage_url": "https://github.com/samx1a/eye_protector"
}
